{
  "name": "@unchainedsky/coral",
  "version": "0.1.0",
  "description": "Passive append-only knowledge reef for Search Agent Sky.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./ui": {
      "types": "./src/index.d.ts",
      "import": "./src/ui.js"
    },
    "./explorer": {
      "types": "./src/index.d.ts",
      "import": "./src/explorer.js"
    },
    "./reef": {
      "types": "./src/index.d.ts",
      "import": "./src/reef.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "examples/demo.js",
    "examples/searchagentsky-producer.js",
    "examples/reef-realistic-data-demo.html",
    "README.md"
  ],
  "scripts": {
    "demo": "node examples/demo.js",
    "lint": "node --check src/*.js && node --check test/*.test.js && node --check examples/*.js",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "agent-memory",
    "jsonl",
    "searchagentsky",
    "research"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  }
}
